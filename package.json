{
  "name": "motionbricks-practical",
  "version": "0.1.0",
  "description": "Practical game-animation pipeline on top of NVIDIA MotionBricks (align → bake → integrate): rig certification with absolute gates, keyframe-driven motion generation with QA gates, and engine-agnostic runtime integration",
  "type": "module",
  "main": "align.js",
  "exports": {
    ".": "./align.js",
    "./retarget": "./retarget.js",
    "./rigmap": "./rigmap.js",
    "./glbskel": "./glbskel.mjs"
  },
  "bin": {
    "motionbricks-certify": "./certify.mjs"
  },
  "scripts": {
    "test": "node selftest.mjs"
  },
  "dependencies": {
    "three": "^0.160.0",
    "@gltf-transform/core": "^4.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/htdt/motionbricks-practical.git"
  },
  "files": [
    "align.js",
    "retarget.js",
    "rigmap.js",
    "glbskel.mjs",
    "certify.mjs",
    "selftest.mjs",
    "README.md",
    "ALIGN.md",
    "BAKE.md",
    "MOTIONBRICKS.md",
    "INTEGRATE.md",
    "motionbricks/"
  ]
}
