{
  "name": "kimodo-practical",
  "version": "0.2.0",
  "description": "Practical game-animation pipeline on top of NVIDIA Kimodo (align → bake → integrate): rig certification with absolute gates, text-prompted motion generation with QA gates, and engine-agnostic runtime integration",
  "type": "module",
  "main": "align.js",
  "exports": {
    ".": "./align.js",
    "./retarget": "./retarget.js",
    "./rigmap": "./rigmap.js",
    "./glbskel": "./glbskel.mjs",
    "./prebake": "./prebake.mjs"
  },
  "bin": {
    "kimodo-certify": "./certify.mjs"
  },
  "scripts": {
    "test": "node selftest.mjs"
  },
  "dependencies": {
    "three": "^0.160.0",
    "@gltf-transform/core": "^4.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/htdt/kimodo-practical.git"
  },
  "files": [
    "align.js",
    "retarget.js",
    "rigmap.js",
    "glbskel.mjs",
    "certify.mjs",
    "prebake.mjs",
    "qa_endeffectors.mjs",
    "selftest.mjs",
    "README.md",
    "ALIGN.md",
    "BAKE.md",
    "KIMODO.md",
    "INTEGRATE.md",
    "kimodo/"
  ]
}
